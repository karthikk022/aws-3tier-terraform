aws_region       = "us-east-1"
environment      = "dev"
project_name     = "3tier-app"

availability_zones   = ["us-east-1a", "us-east-1b"]
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
app_subnet_cidrs     = ["10.0.10.0/24", "10.0.11.0/24"]
db_subnet_cidrs      = ["10.0.20.0/24", "10.0.21.0/24"]

web_instance_type = "t3.micro"
app_instance_type = "t3.micro"

# Amazon Linux 2 AMI (us-east-1)
ami_id = "ami-0c02fb55956c7d316"

# EC2 key pair for SSH (set to null if not needed)
key_name = null

db_username          = "admin"
db_password          = "ChangeMe123!"
db_name              = "appdb"
db_engine            = "mysql"
db_engine_version    = "8.0"
db_instance_class    = "db.t3.micro"
skip_final_snapshot  = true

web_min_size        = 1
web_max_size        = 3
web_desired_capacity = 2

app_min_size         = 1
app_max_size         = 3
app_desired_capacity = 1
